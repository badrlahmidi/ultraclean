APP_NAME="UltraClean"
APP_ENV=production
APP_KEY=                            # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://ultraclean.ma
APP_MAINTENANCE_DRIVER=file

APP_TIMEZONE=Africa/Casablanca
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_MA

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Base de données MySQL Hostinger ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=uXXXXXXXX_ultraclean
DB_USERNAME=uXXXXXXXX_ultraclean
DB_PASSWORD=VOTRE_MOT_DE_PASSE_DB

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=pusher

# ─── Pusher (remplace Reverb sur hébergement partagé Hostinger) ─────────────
# Créer un compte gratuit sur https://pusher.com → Channels
# Free tier : 100 connexions, 200k messages/jour
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Reverb désactivé en production (nécessite un processus persistant)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ─── Queue ─────────────────────────────────────────────────────────────────
# Hostinger Business+ → ajouter cron toutes les minutes :
#   php /home/uXXXX/domains/ultraclean.ma/public_html/artisan schedule:run
# Hostinger Starter (pas de cron) → utiliser QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=noreply@VOTRE_DOMAINE.com
MAIL_PASSWORD=VOTRE_MOT_DE_PASSE_MAIL
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@VOTRE_DOMAINE.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ── Webhook paiement ─────────────────────────────────────────────────────────
# OBLIGATOIRE en production : générer avec `openssl rand -hex 32`
PAYMENT_WEBHOOK_SECRET=VOTRE_SECRET_HMAC

# ── Sentry (error monitoring) ────────────────────────────────────────────────
# DSN depuis https://sentry.io → Settings → Projects → Client Keys (DSN)
SENTRY_LARAVEL_DSN=https://VOTRE_CLE@oXXXXXX.ingest.de.sentry.io/XXXXXXX
SENTRY_TRACES_SAMPLE_RATE=0.2
