APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Initial seed credentials ─────────────────────────────────────────────────
# These values are used ONLY by AdminUserSeeder on first `php artisan db:seed`.
# Leave blank in development (random passwords will be printed to console).
# In production: set strong values here BEFORE running db:seed, then delete them.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_PIN=
SEED_CAISSIER_EMAIL=
SEED_CAISSIER_PASSWORD=
SEED_CAISSIER_PIN=
SEED_LAVEUR_EMAIL=
SEED_LAVEUR_PASSWORD=
SEED_LAVEUR_PIN=

# ── Reverb (développement local) ──────────────────────────────────────────────
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Pusher (production Hostinger — remplace Reverb) ───────────────────────────
# Laisser vide en dev, remplir en prod (echo.js détecte automatiquement)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu
PUSHER_PORT=443
PUSHER_SCHEME=https
VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ── Webhook paiement ──────────────────────────────────────────────────────────
# Secret HMAC-SHA256 pour sécuriser les webhooks de confirmation de paiement.
# Laisser vide pour désactiver la vérification HMAC (dev uniquement).
# En production : générer avec `openssl rand -hex 32`
PAYMENT_WEBHOOK_SECRET=

# ── Sentry (error monitoring) ────────────────────────────────────────────────
# Laisser vide en dev local. En production, récupérer le DSN depuis
# https://sentry.io → Settings → Projects → Client Keys (DSN)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
